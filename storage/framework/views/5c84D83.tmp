											<span
												class="text-muted fw-bold me-2"><?php echo e(getPercent($buildingStats['fully_damaged'], $totalAssessed)); ?>%</span>
											<div class="progress h-6px w-100px">
												<div class="progress-bar bg-danger" role="progressbar"
