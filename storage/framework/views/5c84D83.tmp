									$totalAssessed = $buildingStats['fully_damaged'] + $buildingStats['partially_damaged'] + $buildingStats['committee_review'];

									function getPercent($val, $total)
									{
										return $total > 0 ? round(($val / $total) * 100, 1) : 0;
									}
								?>

